# ==============================================================================
# Harness Engineering - Environment Variables Template
# 이 파일을 .env.local 로 복사하여 실제 값을 입력하십시오.
# 절대 .env.local 을 커밋하지 마세요.
# ==============================================================================

# 1. Slack Telemetry (작업 완료/실패 알림)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# 2. GitHub
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_USER_NAME="Your Name"
GITHUB_USER_EMAIL="you@example.com"

# 3. Harness
TASK_ID=local
# interactive: Codex/Cursor/Claude Code 같은 대화형 도구 사용
# api: scripts/run-agent.sh 로 API-key 기반 에이전트 직접 호출
HARNESS_AGENT_MODE=interactive
# true: verify 단계 실패 시 자율 진단 및 복구 가이드 생성 (HARNESS_AGENT_MODE=api 필수)
HARNESS_DIAGNOSE=false
# true: 저위험 소스/테스트 파일에 한해 AI 패치를 1회 적용하고 재검증 (HARNESS_AGENT_MODE=api 필수)
HARNESS_AUTO_FIX=false
# 5: 선택형 L5 Experimental. 기본값 4.5
HARNESS_AUTONOMY_LEVEL=4.5
# L5 한 번 실행에서 처리할 최대 티켓 수/API 호출 수/실행 시간
HARNESS_MAX_ITERATIONS=3
HARNESS_MAX_API_CALLS=6
HARNESS_MAX_RUNTIME_MINUTES=30
# 일시적 네트워크/429/5xx 재시도 횟수와 지수 백오프 범위(ms)
HARNESS_API_MAX_RETRIES=3
HARNESS_API_RETRY_BASE_MS=1000
HARNESS_API_RETRY_MAX_MS=30000
# 재시도를 포함한 프로세스당 provider HTTP 요청 상한
HARNESS_MAX_PROVIDER_REQUESTS=12
# L5 패치 크기와 파일 수 제한
HARNESS_L5_MAX_PATCH_KB=500
HARNESS_L5_MAX_FILES=20
# true: 검증 통과 후 현재 브랜치에 자동 커밋. main/master에서는 항상 차단
HARNESS_AUTO_COMMIT=false
# true: 자동 커밋 후 현재 브랜치를 origin에 push
HARNESS_AUTO_PUSH=false
# true: Slack 알림 및 AI Semantic Review를 생략하고 오프라인 검증
HARNESS_OFFLINE=false

# 4. AI Provider (run-agent.sh 에서 사용)
# 사용할 provider 선택: openai | anthropic | gemini
AI_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.2
OPENAI_MODEL_FAST=gpt-5-mini
OPENAI_MODEL_STRONG=gpt-5.2

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MODEL_FAST=claude-haiku-4-5
ANTHROPIC_MODEL_STRONG=claude-opus-4-7

# Google Gemini
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-3-flash
GEMINI_MODEL_FAST=gemini-3-flash
GEMINI_MODEL_STRONG=gemini-3-1-pro
