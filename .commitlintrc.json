{
  "extends": ["@commitlint/config-conventional"],
  "rules": {
    "type-enum": [
      2,
      "always",
      ["feat", "fix", "refactor", "test", "docs", "chore", "experiment"]
    ],
    "scope-empty": [1, "never"],
    "subject-empty": [2, "never"],
    "subject-max-length": [2, "always", 72],
    "subject-case": [0, "always"]
  }
}
